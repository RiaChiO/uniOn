{
  "name": "project",
  "version": "1.0.0",
  "description": "Hybrid recommendation system (Node + React Dashboard)",
  "main": "backend/app.js",
  "type": "module",
  "scripts": {
    "start": "node backend/app.js",
    "dev": "npm --prefix ./frontend run dev",
    "dev:test": "npm --prefix ./frontend run dev:test",
    "api": "node backend/app.js",
    "api:test": "cross-env ALLOW_TEST_LOGIN=true VITE_ALLOW_TEST_LOGIN=true node backend/app.js",
    "demo": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-demo.ps1",
    "demo:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-demo.ps1 -ResetData",
    "demo:bat": "scripts\\run-demo.bat keep",
    "demo:bat:reset": "scripts\\run-demo.bat reset",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:seed": "node backend/logic/seed-postgres.js",
    "db:init": "npm run db:up && npm run db:seed"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "keywords": [
    "recommendation",
    "firebase"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
